<div class="divinity-points-popup-config">

  {{!-- Header: icon + current / max inputs --}}
  <div class="form-group dnd5e2 item dp-popup">
    <div class="form-fields">
      <img class="item-image gold-icon"
           src="{{img}}"
           width="60" height="60"
           style="margin-right:10px"
           alt="{{name}}" />

      <div class="form-group label-top">
        <label>{{localize "DND5E.Current"}}</label>
        <div class="form-fields">
          <input type="number"
                 class="number-lg dp-number"
                 name="uses.value"
                 value="{{uses.value}}"
                 placeholder="{{uses.value}}"
                 data-tooltip="{{localize 'dnd5e-divinitypoints.currentDpOverride' dpResource=name}}" />
        </div>
      </div>

      <div class="form-group label-top">
        <label>{{localize "DND5E.Max"}}</label>
        <div class="form-fields">
          <input type="number"
                 class="number-lg dp-number"
                 name="uses.max"
                 value="{{uses.max}}"
                 placeholder="{{uses.max}}"
                 data-tooltip="{{localize 'dnd5e-divinitypoints.maxDpOverride' dpResource=name}}" />
        </div>
      </div>
    </div>
  </div>

  <hr />

  {{!-- Recalculate button --}}
  <div class="form-group">
    <button type="button" class="unbutton control-button"
            data-action="updateDpMax"
            data-tooltip="{{localize 'dnd5e-divinitypoints.updateDpMaxTooltip' dpResource=name}}">
      {{localize "dnd5e-divinitypoints.updateDpMax" dpResource=name}}
    </button>
  </div>

  <hr />

  {{!-- Recovery entries --}}
  <fieldset class="card">
    <legend>
      <span>{{localize "DND5E.Recovery"}}</span>
      <button type="button" class="unbutton control-button"
              data-action="addRecovery"
              data-tooltip="DND5E.USES.Recovery.Action.Create"
              aria-label="{{localize 'DND5E.USES.Recovery.Action.Create'}}">
        <i class="fas fa-plus" inert></i>
      </button>
    </legend>

    {{#each usesRecovery}}
    <div class="form-group split-group full-width card" data-index="{{@index}}">
      <div class="form-fields">

        {{!-- Period --}}
        <div class="form-group label-top">
          <label>{{localize "DND5E.Period"}}</label>
          <div class="form-fields">
            <select name="{{prefix}}period">
              {{selectOptions
                @root.recoveryPeriods
                selected=source.period
                blank=(localize "DND5E.None")
              }}
            </select>
          </div>
        </div>

        {{!-- Type (hidden for recharge) --}}
        {{#unless (eq source.period "recharge")}}
        <div class="form-group label-top">
          <label>{{localize "DND5E.Recovery"}}</label>
          <div class="form-fields">
            <select name="{{prefix}}type">
              {{selectOptions
                @root.recoveryTypes
                selected=source.type
                blank=(localize "DND5E.None")
              }}
            </select>
          </div>
        </div>
        {{/unless}}

        {{!-- Formula --}}
        {{#if (or (eq source.type "formula") formulaOptions)}}
        <div class="form-group label-top">
          <label>{{localize "DND5E.Formula"}}</label>
          <div class="form-fields">
            {{#if (eq source.type "formula")}}
            <input type="text" name="{{prefix}}formula" value="{{source.formula}}" />
            {{/if}}
            {{#if formulaOptions}}
            <select name="{{prefix}}formula">
              {{selectOptions
                formulaOptions
                selected=source.formula
                blank=(localize "DND5E.None")
              }}
            </select>
            {{/if}}
          </div>
        </div>
        {{/if}}

        {{!-- Delete --}}
        <button type="button" class="unbutton control-button"
                data-action="deleteRecovery"
                data-tooltip="DND5E.USES.Recovery.Action.Delete"
                aria-label="{{localize 'DND5E.USES.Recovery.Action.Delete'}}">
          <i class="fas fa-minus" inert></i>
        </button>

      </div>
    </div>
    {{else}}
    <div class="empty">{{localize "DND5E.UsesPeriods.Never"}}</div>
    {{/each}}

  </fieldset>
</div>
