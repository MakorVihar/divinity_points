<div class="dp-settings-form">

  <div class="form-group">
    <label>{{localize "dnd5e-divinitypoints.dpResourceBarLeftColor"}}</label>
    <div class="form-fields">
      <color-picker name="colorL" value="{{colorL}}"></color-picker>
    </div>
  </div>

  <div class="form-group">
    <label>{{localize "dnd5e-divinitypoints.dpResourceBarRightColor"}}</label>
    <div class="form-fields">
      <color-picker name="colorR" value="{{colorR}}"></color-picker>
    </div>
  </div>

  <div class="form-group">
    <label>{{localize "dnd5e-divinitypoints.dpResourceBarAnimate"}}</label>
    <div class="form-fields">
      <input type="checkbox" name="animate" {{#if animate}}checked{{/if}} />
    </div>
  </div>

</div>

<div class="dp-preview-section">
  <label>{{localize "dnd5e-divinitypoints.barPreview"}}</label>
  <div class="dp-preview-bar">
    <div class="dp-preview-fill"></div>
  </div>
</div>
